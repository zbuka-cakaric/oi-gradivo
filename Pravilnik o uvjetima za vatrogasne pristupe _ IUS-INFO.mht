------MultipartBoundary--4MLifKMJ9XLDBo05AC6nAUEshsZMv7rnA7pZXdjnsm----
Content-Type: text/css
Content-Transfer-Encoding: binary
Content-Location: https://www.iusinfo.hr/Content/Document/Comment.css

@charset "utf-8";

.row[commentid] { margin-right: -30px; margin-left: -30px; }

.row[article="0"] { margin-right: -15px; margin-left: -15px; }

.divAddComment { width: auto; background-color: rgb(221, 219, 218); display: block; margin: 0px 0px 20px; padding: 5px 3px 20px 15px; }

.divAddComment[article="0"] { margin-right: 0px; margin-left: 0px; }

.content-doc-header-comments { position: relative; right: 14px; top: -6px; float: right; width: 18px; height: 18px; border-radius: 9px; font-size: 10px; color: rgb(255, 255, 255); line-height: 18px; text-align: center; background: rgb(225, 30, 37); cursor: pointer; z-index: 999; }

.content-doc-links-comments { position: absolute; top: 0px; right: 0px; min-width: 20px; height: 20px; background-color: rgb(72, 72, 72); color: white; border: 3px solid rgb(72, 72, 72); border-radius: 16px; text-align: center; font-size: 12px; z-index: 0; line-height: 1.3; }

.content-doc-comment-back { padding: 20px 15px; margin-bottom: 15px; background-repeat: no-repeat; background-position: right bottom; background-size: 28px; border-bottom-right-radius: 27px; }

.lnkEditComment img { position: absolute; margin-left: 10px; }

.lnkDeleteComment img { position: absolute; margin-left: 35px; }

.lnkDeleteComment:hover { opacity: 0.8; }

.lnkEditComment:hover { opacity: 0.8; }

.comment-back { padding: 20px 15px; margin-bottom: 5px; }

.comment-back-personal { background-color: rgb(221, 219, 218); background-image: url("/Content/Images/pasica-izsek-prikaz-opombe_1.svg"); }

.comment-back-revoked { background-color: rgb(216, 225, 232); color: rgb(170, 170, 170); background-image: url("/Content/Images/pasica-izsek-prikaz-opombe_2.svg"); }

.comment-back-public { background-color: rgb(211, 232, 248); background-image: url("/Content/Images/pasica-izsek-prikaz-opombe_3.svg"); }

.comment-fold { position: absolute; width: 30px; right: 15px; bottom: 40px; }

label { cursor: pointer !important; }

input[type="checkbox"] + label::before { width: 37px; content: url("/Content/Images/checkbox_empty.svg") !important; display: inline-block !important; margin: 0px 0.6em 0px 0px !important; padding: 0px !important; vertical-align: middle !important; }

input[type="checkbox"]:checked + label::before { width: 37px; content: url("/Content/Images/checkbox_full.svg") !important; text-align: center !important; }

span.comment-checkbox { background-image: url("/Content/Images/checkbox_empty.svg") !important; display: inline-block !important; margin: 0px 0.4em 0px 0px !important; padding: 0px !important; vertical-align: middle !important; width: 37px !important; height: 37px !important; }

.dynatree-selected span.dynatree-checkbox { background-image: url("/Content/Images/checkbox_full.svg") !important; }

.divAddCommentText { display: grid; grid-template-columns: repeat(2, 50%); grid-template-rows: 85% auto; grid-template-areas: "tArea tArea" "leftCol rightCol"; }

.divAddCommentText.contract textarea.txtAddComment { min-height: 60px; }

.txtAddComment { width: 98%; margin: 8px 0px; border-width: medium; border-style: none; border-color: currentcolor; border-image: none; padding: 10px 15px; color: rgb(210, 206, 204); font-weight: bold; grid-area: tArea; }

.divCommentPublic { grid-area: leftCol; align-self: center; }

.divCommentSave { grid-area: rightCol; text-align: right; margin-right: 15px; align-self: center; }

.btnCancelComment { background-color: rgb(240, 240, 240); border-color: rgb(240, 240, 240); color: inherit; }

@media only screen and (max-width: 434.98px) {
  .divAddCommentText { display: flex; flex-direction: column; }
  .divCommentSave { padding-top: 10px; }
  .divAddComment { padding-left: 11px; }
}

@media (max-width: 565px) {
  .content-doc-comment-public { display: none; }
}
