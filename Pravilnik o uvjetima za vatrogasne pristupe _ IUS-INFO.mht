.swal2-toast div:where(.swal2-html-container) { margin: 0.5em 1em; padding: 0px; overflow: initial; font-size: 1em; text-align: initial; }

.swal2-toast div:where(.swal2-html-container):empty { padding: 0px; }

.swal2-toast .swal2-loader { grid-area: 1 / 1 / 99; align-self: center; width: 2em; height: 2em; margin: 0.25em; }

